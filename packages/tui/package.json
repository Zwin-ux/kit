{
  "name": "@kit-skills/tui",
  "version": "0.0.0",
  "private": true,
  "description": "Pixel-art terminal interface for Kit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('@kit-skills/tui: no tests yet')\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@kit-skills/core": "workspace:*",
    "@kit-skills/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
