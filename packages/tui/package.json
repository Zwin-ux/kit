{
  "name": "@mzwin/kit-tui",
  "version": "0.1.3",
  "description": "Pixel-art terminal interface for Kit",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zwin-ux/kit.git",
    "directory": "packages/tui"
  },
  "homepage": "https://github.com/Zwin-ux/kit#readme",
  "bugs": {
    "url": "https://github.com/Zwin-ux/kit/issues"
  },
  "bin": {
    "kit-tui": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:write": "node scripts/write-pack-icons.mjs",
    "banner:write": "node scripts/write-readme-banner.mjs",
    "assets:readme": "python scripts/generate-readme-assets.py",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@mzwin/kit-core": "0.1.3",
    "@mzwin/kit-shared": "0.1.3",
    "ink": "^5.2.1",
    "pngjs": "^7.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.20",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
