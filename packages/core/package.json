{
  "name": "@mzwin/kit-core",
  "version": "0.1.5",
  "description": "Skill parser, validator, and local library for Kit",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zwin-ux/kit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Zwin-ux/kit#readme",
  "bugs": {
    "url": "https://github.com/Zwin-ux/kit/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@mzwin/kit-shared": "workspace:*",
    "semver": "^7.7.2",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/semver": "^7.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
