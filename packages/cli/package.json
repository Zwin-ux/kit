{
  "name": "@mzwin/kit",
  "version": "0.1.2",
  "description": "Kit CLI — portable agent skills for Claude Code, Grok Build, and Codex",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zwin-ux/kit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Zwin-ux/kit#readme",
  "bugs": {
    "url": "https://github.com/Zwin-ux/kit/issues"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "codex",
    "cli",
    "skills",
    "kit"
  ],
  "bin": {
    "kit": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('@mzwin/kit: no tests yet')\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@mzwin/kit-catalog": "workspace:*",
    "@mzwin/kit-core": "workspace:*",
    "@mzwin/kit-shared": "workspace:*",
    "@mzwin/kit-tui": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
