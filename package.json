{
  "name": "kit",
  "version": "0.1.0",
  "private": true,
  "description": "Portable agent skills for Claude Code, Grok Build, and Codex",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm catalog:sync && pnpm -r --filter \"!@mzwin/kit-catalog\" run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "kit": "node packages/cli/dist/bin.js",
    "tui": "node packages/cli/dist/bin.js tui",
    "init": "node packages/cli/dist/bin.js init",
    "doctor": "node packages/cli/dist/bin.js doctor",
    "test:packs": "node packages/cli/dist/bin.js test --all-packs",
    "keep-alive": "node scripts/keep-alive.mjs",
    "catalog:sync": "node scripts/sync-catalog-package.mjs",
    "plugin:claude": "node scripts/sync-claude-plugin.mjs",
    "publish:all": "node scripts/publish.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
