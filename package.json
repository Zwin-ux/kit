{
  "name": "kit",
  "version": "0.0.0",
  "private": true,
  "description": "Portable agent skills for Claude Code, Grok Build, and Codex",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "kit": "pnpm --filter @kit-skills/cli exec node dist/bin.js",
    "tui": "pnpm --filter @kit-skills/tui start",
    "init": "pnpm --filter @kit-skills/cli exec node dist/bin.js init",
    "doctor": "pnpm --filter @kit-skills/cli exec node dist/bin.js doctor",
    "test:packs": "pnpm --filter @kit-skills/cli exec node dist/bin.js test --all-packs"
  },

  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
